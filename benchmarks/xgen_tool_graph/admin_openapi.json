{
  "openapi": "3.0.3",
  "info": {
    "title": "XGEN Admin Tool Graph Benchmark API",
    "version": "1.0.0"
  },
  "paths": {
    "/admin/users/search": {
      "get": {
        "operationId": "searchUsers",
        "summary": "мӮ¬мҡ©мһҗ кІҖмғү Search users by email or name",
        "tags": ["admin", "users"],
        "parameters": [
          {"name": "email", "in": "query", "schema": {"type": "string"}},
          {"name": "keyword", "in": "query", "schema": {"type": "string"}},
          {"name": "tenantId", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "users": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "userId": {"type": "string"},
                          "email": {"type": "string"},
                          "displayName": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "x-graph-tool-call": {
          "context_field_names": ["tenantId"],
          "search_filter_field_names": ["email", "keyword"],
          "ai_metadata": {
            "one_line_summary": "мқҙл©”мқјмқҙлӮҳ мқҙлҰ„мңјлЎң кҙҖлҰ¬ лҢҖмғҒ мӮ¬мҡ©мһҗлҘј кІҖмғүн•ҳкі  userIdлҘј м°ҫлҠ”лӢӨ",
            "when_to_use": "мӮ¬мҡ©мһҗ кі„м •, к¶Ңн•ң, м„ём…ҳ, к°җмӮ¬ мқҙл Ҙ мһ‘м—… м „м—җ лҢҖмғҒ мӮ¬мҡ©мһҗлҘј м°ҫмқ„ л•Ң мӮ¬мҡ©",
            "primary_resource": "user",
            "canonical_action": "search",
            "produces_semantics": [
              {"json_path": "$.users[*].userId", "semantic": "user_id"},
              {"json_path": "$.users[*].email", "semantic": "email"}
            ],
            "consumes_semantics": [
              {"field": "email", "semantic": "email", "kind": "data"},
              {"field": "keyword", "semantic": "search_keyword", "kind": "data"},
              {"field": "tenantId", "semantic": "tenant_id", "kind": "context"}
            ]
          }
        }
      }
    },
    "/admin/roles": {
      "get": {
        "operationId": "listRoles",
        "summary": "м—ӯн•  лӘ©лЎқ мЎ°нҡҢ List admin roles and permission roles",
        "tags": ["admin", "roles"],
        "parameters": [
          {"name": "roleName", "in": "query", "schema": {"type": "string"}},
          {"name": "tenantId", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "roles": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "roleId": {"type": "string"},
                          "roleName": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "x-graph-tool-call": {
          "context_field_names": ["tenantId"],
          "search_filter_field_names": ["roleName"],
          "ai_metadata": {
            "one_line_summary": "к¶Ңн•ң л¶Җм—¬м—җ мӮ¬мҡ©н•  roleIdмҷҖ м—ӯн• лӘ…мқ„ мЎ°нҡҢн•ңлӢӨ",
            "when_to_use": "кҙҖлҰ¬мһҗ, мҡҙмҳҒмһҗ, к¶Ңн•ң м—ӯн• мқ„ мӮ¬мҡ©мһҗм—җкІҢ л¶Җм—¬н•ҳкё° м „ roleIdк°Җ н•„мҡ”н•  л•Ң мӮ¬мҡ©",
            "primary_resource": "role",
            "canonical_action": "search",
            "produces_semantics": [
              {"json_path": "$.roles[*].roleId", "semantic": "role_id"},
              {"json_path": "$.roles[*].roleName", "semantic": "role_name"}
            ],
            "consumes_semantics": [
              {"field": "roleName", "semantic": "role_name", "kind": "data"},
              {"field": "tenantId", "semantic": "tenant_id", "kind": "context"}
            ]
          }
        }
      }
    },
    "/admin/users/{userId}/roles": {
      "post": {
        "operationId": "assignRoleToUser",
        "summary": "мӮ¬мҡ©мһҗ м—ӯн•  к¶Ңн•ң л¶Җм—¬ Assign a role to a user",
        "tags": ["admin", "roles"],
        "parameters": [
          {"name": "userId", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "tenantId", "in": "query", "schema": {"type": "string"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["roleId"],
                "properties": {
                  "roleId": {"type": "string"},
                  "reason": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "userId": {"type": "string"},
                    "roleId": {"type": "string"},
                    "assignmentId": {"type": "string"}
                  }
                }
              }
            }
          }
        },
        "x-graph-tool-call": {
          "context_field_names": ["tenantId"],
          "ai_metadata": {
            "one_line_summary": "лҢҖмғҒ мӮ¬мҡ©мһҗм—җкІҢ кҙҖлҰ¬мһҗ лҳҗлҠ” мҡҙмҳҒ м—ӯн•  к¶Ңн•ңмқ„ л¶Җм—¬н•ңлӢӨ",
            "when_to_use": "мӮ¬мҡ©мһҗм—җкІҢ roleId кё°л°ҳ к¶Ңн•ңмқҙлӮҳ кҙҖлҰ¬мһҗ м—ӯн• мқ„ м¶”к°Җн•  л•Ң мӮ¬мҡ©",
            "primary_resource": "user_role",
            "canonical_action": "update",
            "pairs_well_with": [
              {"tool": "searchUsers", "reason": "searchUsers discovers userId from email", "source": "auto"},
              {"tool": "listRoles", "reason": "listRoles discovers roleId from role name", "source": "auto"}
            ],
            "produces_semantics": [
              {"json_path": "$.assignmentId", "semantic": "assignment_id"}
            ],
            "consumes_semantics": [
              {"field": "userId", "semantic": "user_id", "kind": "data"},
              {"field": "roleId", "semantic": "role_id", "kind": "data"},
              {"field": "tenantId", "semantic": "tenant_id", "kind": "context"}
            ]
          }
        }
      }
    },
    "/admin/audit/logs": {
      "get": {
        "operationId": "getAuditLogs",
        "summary": "мӮ¬мҡ©мһҗ к°җмӮ¬ лЎңк·ё мЎ°нҡҢ Get user audit logs",
        "tags": ["admin", "audit"],
        "parameters": [
          {"name": "userId", "in": "query", "required": true, "schema": {"type": "string"}},
          {"name": "tenantId", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "logs": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "auditId": {"type": "string"},
                          "userId": {"type": "string"},
                          "action": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "x-graph-tool-call": {
          "context_field_names": ["tenantId"],
          "ai_metadata": {
            "one_line_summary": "мӮ¬мҡ©мһҗмқҳ кі„м • ліҖкІҪ, к¶Ңн•ң ліҖкІҪ, лЎңк·ёмқё к°җмӮ¬ мқҙл Ҙмқ„ мЎ°нҡҢн•ңлӢӨ",
            "when_to_use": "нҠ№м • мӮ¬мҡ©мһҗмқҳ кі„м • ліҖкІҪ лӮҙм—ӯмқҙлӮҳ к°җмӮ¬ лЎңк·ёлҘј нҷ•мқён•  л•Ң мӮ¬мҡ©",
            "primary_resource": "audit_log",
            "canonical_action": "read",
            "pairs_well_with": [
              {"tool": "searchUsers", "reason": "searchUsers discovers userId from email", "source": "auto"}
            ],
            "produces_semantics": [
              {"json_path": "$.logs[*].auditId", "semantic": "audit_id"}
            ],
            "consumes_semantics": [
              {"field": "userId", "semantic": "user_id", "kind": "data"},
              {"field": "tenantId", "semantic": "tenant_id", "kind": "context"}
            ]
          }
        }
      }
    },
    "/admin/users/{userId}/sessions": {
      "get": {
        "operationId": "listUserSessions",
        "summary": "мӮ¬мҡ©мһҗ м„ём…ҳ мЎ°нҡҢ List active user sessions",
        "tags": ["admin", "sessions"],
        "parameters": [
          {"name": "userId", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "tenantId", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sessions": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "sessionId": {"type": "string"},
                          "userId": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "x-graph-tool-call": {
          "context_field_names": ["tenantId"],
          "ai_metadata": {
            "one_line_summary": "мӮ¬мҡ©мһҗмқҳ нҷңм„ұ лЎңк·ёмқё м„ём…ҳкіј sessionIdлҘј мЎ°нҡҢн•ңлӢӨ",
            "when_to_use": "к°•м ң лЎңк·ём•„мӣғмқҙлӮҳ м„ём…ҳ мў…лЈҢ м „м—җ лҢҖмғҒ sessionIdк°Җ н•„мҡ”н•  л•Ң мӮ¬мҡ©",
            "primary_resource": "session",
            "canonical_action": "read",
            "pairs_well_with": [
              {"tool": "searchUsers", "reason": "searchUsers discovers userId from email", "source": "auto"}
            ],
            "produces_semantics": [
              {"json_path": "$.sessions[*].sessionId", "semantic": "session_id"},
              {"json_path": "$.sessions[*].userId", "semantic": "user_id"}
            ],
            "consumes_semantics": [
              {"field": "userId", "semantic": "user_id", "kind": "data"},
              {"field": "tenantId", "semantic": "tenant_id", "kind": "context"}
            ]
          }
        }
      }
    },
    "/admin/sessions/{sessionId}/revoke": {
      "post": {
        "operationId": "revokeUserSession",
        "summary": "мӮ¬мҡ©мһҗ м„ём…ҳ к°•м ң мў…лЈҢ Force logout and revoke a user session",
        "tags": ["admin", "sessions"],
        "parameters": [
          {"name": "sessionId", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "tenantId", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sessionId": {"type": "string"},
                    "revoked": {"type": "boolean"}
                  }
                }
              }
            }
          }
        },
        "x-graph-tool-call": {
          "context_field_names": ["tenantId"],
          "ai_metadata": {
            "one_line_summary": "нҷңм„ұ sessionIdлҘј к°•м ң мў…лЈҢн•ҙ мӮ¬мҡ©мһҗлҘј лЎңк·ём•„мӣғмӢңнӮЁлӢӨ",
            "when_to_use": "мӮ¬мҡ©мһҗмқҳ лЎңк·ёмқё м„ём…ҳмқ„ revokeн•ҳкұ°лӮҳ к°•м ң лЎңк·ём•„мӣғ мІҳлҰ¬н•  л•Ң мӮ¬мҡ©",
            "primary_resource": "session",
            "canonical_action": "update",
            "pairs_well_with": [
              {"tool": "listUserSessions", "reason": "listUserSessions discovers sessionId", "source": "auto"}
            ],
            "consumes_semantics": [
              {"field": "sessionId", "semantic": "session_id", "kind": "data"},
              {"field": "tenantId", "semantic": "tenant_id", "kind": "context"}
            ]
          }
        }
      }
    }
  }
}
