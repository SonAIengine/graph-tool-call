{
  "openapi": "3.1.0",
  "info": {"title": "Orders API", "version": "2.0.0"},
  "paths": {
    "/orders": {
      "get": {
        "operationId": "listOrders",
        "summary": "List orders",
        "responses": {"200": {"description": "Order list"}}
      },
      "post": {
        "summary": "Create an order",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/NewOrder"}
            }
          }
        },
        "responses": {"201": {"description": "Order created"}}
      }
    }
  },
  "components": {
    "schemas": {
      "NewOrder": {
        "type": "object",
        "required": ["item"],
        "properties": {
          "item": {"type": "string"},
          "note": {"anyOf": [{"type": "string"}, {"type": "null"}]}
        }
      }
    }
  }
}
